/*
 * DISPOSITIVO BÍCEPS: Adquisición RAW a 100Hz (Sin cálculos pesados)
 * Envía: Tiempo (ms), Rojo Crudo, IR Crudo
 */

#include <Wire.h>
#include "MAX30105.h"

MAX30105 particleSensor;
unsigned long tiempoInicio = 0;

void setup() {
  Serial.begin(115200);
  delay(1000);
  Wire.begin(21, 22);
  Wire.setClock(400000); // I2C muy rápido

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    while (1) { yield(); }
  }

  // ADC Range 16384, sample rate 100
  particleSensor.setup(60, 4, 2, 100, 411, 16384);
  particleSensor.setPulseAmplitudeRed(0x7A);
  particleSensor.setPulseAmplitudeIR(0x3F);

  tiempoInicio = millis();
}

void loop() {
  particleSensor.check();
  
  // Vaciamos el buffer a 100Hz directamente a MATLAB
  while (particleSensor.available()) {
    Serial.print(millis() - tiempoInicio);
    Serial.print(",");
    Serial.print(particleSensor.getFIFORed());
    Serial.print(",");
    Serial.println(particleSensor.getFIFOIR());
    
    particleSensor.nextSample();
  }
}
