#include <Wire.h>
#include <MPU6050.h>
#include <MAX30105.h>
#include "heartRate.h"

MPU6050 mpu;
MAX30105 particleSensor;

// ---- FC Promedio ----
#define RATE_SIZE 5
float rates[RATE_SIZE];
byte rateSpot = 0;
byte beatCount = 0;
long lastBeat = 0;
float avgBPM = 0;

// ---- Movimiento ----
float umbralMovimiento = 20000;

void setup() {
  Serial.begin(115200);
  Wire.begin(8, 9);

  // MPU6050
  mpu.initialize();

  // MAX30102
  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    while (1);
  }

particleSensor.setup(
  255,    // brillo LED (0-255)
  4,     // promedio de muestras (1,2,4,8,16,32)
  2,     // modo LED (2 = Red + IR)
  100,   // frecuencia de muestreo (Hz)
  411,   // ancho de pulso (µs)
  4096   // rango ADC
);  

  particleSensor.setPulseAmplitudeRed(0x0A);
  particleSensor.setPulseAmplitudeIR(0x1F);
}

void loop() {

  // ===== MOVIMIENTO =====
  int16_t ax, ay, az;
  mpu.getAcceleration(&ax, &ay, &az);

  float mag = sqrt(ax * ax + ay * ay + az * az);

  int evento = 0;
  if (mag > umbralMovimiento) {
    evento = 1;
  }

  // ===== FRECUENCIA CARDIACA =====
  long irValue = particleSensor.getIR();

  if (checkForBeat(irValue)) {

    long delta = millis() - lastBeat;
    lastBeat = millis();

    float bpm = 60.0 / (delta / 1000.0);

    if (bpm > 40 && bpm < 180) {

      rates[rateSpot++] = bpm;
      rateSpot %= RATE_SIZE;

      if (beatCount < RATE_SIZE) {
        beatCount++;
      }

      if (beatCount == RATE_SIZE) {
        avgBPM = 0;
        for (byte i = 0; i < RATE_SIZE; i++) {
          avgBPM += rates[i];
        }
        avgBPM /= RATE_SIZE;
      }
    }
  }

  // ===== SALIDA PARA SERIAL PLOTTER =====
  Serial.print(mag);
  Serial.print(" ");
  Serial.print(evento * 30000);  // escalar evento para que se vea
  Serial.print(" ");
  Serial.println(avgBPM * 300);  // escalar FC para visualización

  delay(20);
}
