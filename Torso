#include <Wire.h>
#include "MAX30105.h"

MAX30105 particleSensor;

const int PIN_ECG = 4;
const int PIN_LO_PLUS = 18;
const int PIN_LO_MINUS = 17;

const unsigned long DURATION_SECONDS = 30;
const int SAMPLING_FREQ_HZ = 100;

unsigned long startTime;
unsigned long lastSampleTime = 0;
const unsigned long sampleInterval = 1000 / SAMPLING_FREQ_HZ;

bool isRunning = true;

// Filtros
float ecgFiltered = 0;
float redFiltered = 0;
float irFiltered = 0;

void setup() {

  Serial.begin(115200);

  pinMode(PIN_ECG, INPUT);
  pinMode(PIN_LO_PLUS, INPUT);
  pinMode(PIN_LO_MINUS, INPUT);

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    Serial.println("MAX30102 no detectado");
  }

  particleSensor.setup(60, 8, 2, 100, 411, 16384);

  Serial.println("Inicio Torso...;Tiempo,ECG,Red,IR");

  startTime = millis();
}

void loop() {

  unsigned long currentTime = millis();

  if ((currentTime - startTime) > (DURATION_SECONDS * 1000)) {

    if (isRunning) {
      Serial.println("FIN_MUESTREO");
      isRunning = false;
    }

    return;
  }

  if (currentTime - lastSampleTime >= sampleInterval && isRunning) {

    lastSampleTime = currentTime;

    unsigned long t = currentTime - startTime;

    int ecgRaw = analogRead(PIN_ECG);

    if ((digitalRead(PIN_LO_PLUS) == 1) || (digitalRead(PIN_LO_MINUS) == 1)) {
      ecgRaw = 0;
    }

    ecgFiltered = 0.1 * ecgRaw + 0.9 * ecgFiltered;

    uint32_t red = particleSensor.getRed();
    uint32_t ir  = particleSensor.getIR();

    redFiltered = 0.1 * red + 0.9 * redFiltered;
    irFiltered  = 0.1 * ir  + 0.9 * irFiltered;

    Serial.print(t);
    Serial.print(",");
    Serial.print(ecgFiltered);
    Serial.print(",");
    Serial.print(redFiltered);
    Serial.print(",");
    Serial.println(irFiltered);
  }
}
